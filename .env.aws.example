# ============================================
# Healthcare App - AWS Environment Configuration
# ============================================
# Copy this to .env and update values for AWS deployment
# Location on EC2: ~/Healthpulse/.env

# ---- Application ----
APP_NAME=HealthPulse Backend
APP_VERSION=1.0.0
DEBUG=False
HOST=0.0.0.0
PORT=8000

# ---- MongoDB (AWS/Atlas) ----
MONGODB_URL=mongodb+srv://your-username:your-password@cluster.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=healthpulse

# ---- JWT Authentication ----
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- CORS ----
CORS_ORIGINS=http://<EC2-IP>,https://your-domain.com

# ---- Logging ----
LOG_LEVEL=INFO

# ---- EC2 Public IP (used by n8n webhook routing) ----
EC2_PUBLIC_IP=<your-ec2-public-ip>    # e.g. 65.0.123.45

# ---- n8n Configuration ----
# Replace <EC2-IP> with your actual EC2 public IP or domain
N8N_HOST=<your-ec2-public-ip>
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://<your-ec2-public-ip>:5678
WEBHOOK_TUNNEL_URL=http://<your-ec2-public-ip>:5678/

# ---- Claude AI (Anthropic) — used by n8n chatbot workflow ----
# Get key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- ZegoCloud Video Calls ----
# These are already hardcoded in frontend — just whitelist your EC2 domain at:
# https://console.zegocloud.com → Security Settings → Allowed Origins
# ZEGO_APP_ID=982964860              # (already in code, for reference)
# ZEGO_SERVER_SECRET=faa14b2d...     # (already in code, for reference)

# ---- Supabase Configuration ----
SUPABASE_SECRET_KEY=your-supabase-secret-key-here
