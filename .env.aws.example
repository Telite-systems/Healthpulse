# ============================================
# Healthcare App - AWS Environment Configuration
# ============================================
# Copy this to .env.aws and update values for AWS deployment

# ---- Application ----
APP_NAME=HealthPulse Backend
APP_VERSION=1.0.0
DEBUG=False
HOST=0.0.0.0
PORT=8000

# ---- MongoDB (AWS/Atlas) ----
MONGODB_URL=mongodb+srv://your-username:your-password@cluster.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=healthpulse

# ---- JWT Authentication ----
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- CORS ----
CORS_ORIGINS=https://your-domain.com,https://n8n.your-domain.com

# ---- Logging ----
LOG_LEVEL=INFO

# ---- n8n Configuration ----
N8N_HOST=n8n.your-domain.com
N8N_PROTOCOL=https
WEBHOOK_TUNNEL_URL=https://n8n.your-domain.com/

# ---- Supabase Configuration ----
SUPABASE_SECRET_KEY=your-supabase-secret-key-here
